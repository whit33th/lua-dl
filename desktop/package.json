{
  "name": "lua-dl-desktop",
  "version": "0.1.2",
  "private": true,
  "description": "Lua-DL Desktop Application",
  "author": "whit33th",
  "main": "dist-electron/main.js",
  "scripts": {
    "postinstall": "powershell -ExecutionPolicy Bypass -File scripts/patch-node-pty.ps1",
    "dev": "concurrently -k \"next dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "dev:next": "next dev",
    "build:go": "powershell -ExecutionPolicy Bypass -File scripts/build-go.ps1",
    "build:next": "next build",
    "build:electron": "tsup",
    "build": "npm run build:next && npm run build:electron",
    "start": "electron .",
    "dist": "npm run build:go && npm run build:next && npm run build:electron && dotenv -- electron-builder --win -p never"
  },
  "dependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "node-pty": "^1.1.0-beta34",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "ansi-regex": "^6.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.12",
    "framer-motion": "^12.23.24",
    "gsap": "^3.13.0",
    "i": "^0.3.7",
    "install": "^0.13.0",
    "lucide-react": "^1.14.0",
    "motion": "^12.23.12",
    "next": "^16.2.5",
    "ogl": "^1.0.11",
    "postcss": "8.4.31",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "strip-ansi": "^7.1.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "three": "^0.167.1",
    "tsup": "^8.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3",
    "zod": "^4.1.13",
    "zustand": "^5.0.13"
  },
  "overrides": {
    "postcss": "8.4.31"
  },
  "browserslist": [
    "> 0.25%",
    "not dead",
    "not op_mini all"
  ]
}
